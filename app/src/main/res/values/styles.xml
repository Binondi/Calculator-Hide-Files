<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Button" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>

        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:layout_marginStart">@dimen/_3sdp</item>
        <item name="android:layout_marginEnd">@dimen/_3sdp</item>
        <item name="android:layout_marginTop">@dimen/_3sdp</item>
        <item name="android:layout_marginBottom">@dimen/_3sdp</item>
    </style>

    <style name="Button.Number">
        <item name="android:textSize">36sp</item>
        <item name="android:autoSizeMaxTextSize">36sp</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:gravity">center</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:background">@drawable/background_button_number</item>
    </style>
    <style name="Button.Operator">
        <item name="android:textSize">46sp</item>
        <item name="android:autoSizeMaxTextSize">46sp</item>
        <item name="android:gravity">center</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:background">@drawable/background_button_operator</item>
    </style>
    <style name="Button.OperatorBigSize">
        <item name="android:textSize">56sp</item>
        <item name="android:autoSizeMaxTextSize">56sp</item>
        <item name="android:gravity">center</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:background">@drawable/background_button_operator</item>
    </style>
    <style name="Button.OperatorMinus">
        <item name="android:textSize">76sp</item>
        <item name="android:autoSizeMaxTextSize">76sp</item>
        <item name="android:gravity">center</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:background">@drawable/background_button_operator</item>
    </style>
    <style name="Button.Equals">
        <item name="android:textSize">54sp</item>
        <item name="android:autoSizeMaxTextSize">54sp</item>
        <item name="android:autoSizeMinTextSize">1sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:background">@drawable/background_button_equals</item>
        <item name="android:text">=</item>
    </style>
    <style name="Button.Backspace">
        <item name="android:background">@drawable/background_button_equals</item>
    </style>


    <style name="Expression" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>

        <item name="android:layout_marginStart">21dp</item>
        <item name="android:layout_marginEnd">21dp</item>
        <item name="android:layout_marginTop">@dimen/_4sdp</item>

        <item name="android:layoutDirection">ltr</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">bottom|right</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:inputType">textMultiLine|textNoSuggestions</item>

        <item name="android:textSize">86sp</item>
        <item name="android:autoSizeMaxTextSize">86sp</item>
        <item name="android:autoSizeMinTextSize">44sp</item>
        <item name="autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>
    </style>
    <style name="Expression.Result">
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:layout_marginBottom">@dimen/_4sdp</item>

        <item name="android:textSize">56sp</item>
        <item name="android:autoSizeMaxTextSize">56sp</item>
        <item name="android:autoSizeMinTextSize">8sp</item>
        <item name="autoSizeStepGranularity">1sp</item>
        <item name="android:autoSizeTextType">uniform</item>

        <item name="android:maxLines">1</item>
        <item name="android:inputType">none</item>
        <item name="android:soundEffectsEnabled">false</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textIsSelectable">true</item>
    </style>

    <style name="AppBarConstraintLayoutCalculator">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>

        <item name="android:layout_marginTop">@dimen/_4sdp</item>

        <item name="android:layoutDirection">locale</item>
    </style>

    <style name="appBar_settings">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?attr/actionBarSize</item>

        <item name="layout_collapseMode">pin</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIcon">@drawable/ic_back</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
        <item name="navigationContentDescription">@string/arrow_back_tool_tip</item>
    </style>

    <style name="optionLayout">
        <item name="android:background">?selectableItemBackground</item>
        <item name="android:clickable">true</item>

        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="optionImage">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>

        <item name="android:layout_marginStart">20dp</item>

        <item name="android:tint">?attr/colorOnSurface</item>
    </style>

    <style name="optionTitleText" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginTop">12dp</item>

        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="optionSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <style name="optionDescriptionText" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">12dp</item>

        <item name="android:textSize">15sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="sectionText" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_marginStart">66dp</item>
        <item name="android:layout_marginTop">48dp</item>

        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="optionHorizontalScroll">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">12dp</item>

        <item name="android:scrollbars">none</item>
    </style>



    <style name="backgroundSelectColor">
        <item name="android:background">@drawable/background_select_color</item>

        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>

        <item name="android:layout_marginStart">8dp</item>

        <item name="android:orientation">horizontal</item>
        <item name="android:clickable">true</item>
        <item name="android:onClick">selectColor</item>
    </style>

